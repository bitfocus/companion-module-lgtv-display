{
	"name": "lgtv-display",
	"version": "2.0.0",
	"type": "module",
	"main": "dist/main.js",
	"scripts": {
		"format": "prettier -w .",
		"build": "rimraf dist && yarn build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw .",
		"package": "yarn build && companion-module-build"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-lgtv-display.git"
	},
