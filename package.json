		"node": "^22.20",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "~1.14.1",
		"lgtv-ip-control": "^4.4.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.7.2",
		"@types/node": "^22.19.17",
		"eslint": "^9.39.4",
		"prettier": "^3.8.4",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.59.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"packageManager": "yarn@4.17.0"
}
